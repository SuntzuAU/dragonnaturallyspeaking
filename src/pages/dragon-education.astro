---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";

const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";
function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) { return manifest[key]?.altText || ""; }
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dragon Software for Education Australia | Student Pricing $545 | Speech Recognition</title>
    <meta name="description" content="Dragon Professional 16 Student Edition for Australian students and educators. $545 AUD perpetual licence. Full version, no feature restrictions. Ideal for dyslexia, RSI and accessibility needs." />
    <link rel="canonical" href={`${site.domain}/dragon-education`} />
    <script define:vars={{ c }}>
      const css = `
        .btn-primary { background: ${c.accent}; border-color: ${c.accent}; color: #fff; }
        .btn-primary:hover { background: ${c.accentHover}; border-color: ${c.accentHover}; }
        .dark-bg { background: ${c.primary}; color: white; }
        .neutral-bg { background: ${c.neutral}; }
        .feature-check { color: ${c.accent}; }
        .spec-badge { background: ${c.accent}; color: #fff; }
      `;
      const el = document.createElement('style');
      el.textContent = css;
      document.head.appendChild(el);
    </script>
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#0f172a;line-height:1.6}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:40px;width:auto}
      .nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155}
      .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
      .hamburger span{display:block;width:22px;height:2px;background:#334155;border-radius:2px}
      .mobile-nav{display:none;padding:12px 0 8px;border-top:1px solid #e2e8f0}
      .mobile-nav a{display:block;padding:10px 0;font-size:15px;font-weight:500;color:#334155;border-bottom:1px solid #f1f5f9}
      section{padding:64px 0}
      .breadcrumb{font-size:13px;color:#64748b;margin-bottom:20px}
      .breadcrumb a{color:#0097a7;font-weight:500}
      .product-hero{padding:48px 0 40px}
      .product-hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
      .product-hero h1{font-size:36px;line-height:1.1;margin:0 0 14px;letter-spacing:-0.03em}
      .product-hero p{font-size:16px;line-height:1.7;margin:0 0 24px;color:#475569}
      .spec-badge{display:inline-block;font-size:11px;font-weight:700;padding:4px 12px;border-radius:999px;margin-bottom:14px;text-transform:uppercase;letter-spacing:.05em}
      .price-display{font-size:48px;font-weight:800;line-height:1;margin:0 0 4px;color:#0d1b2a}
      .price-note{font-size:14px;color:#64748b;margin:0 0 6px}
      .price-save{font-size:14px;color:#006064;font-weight:600;background:#e0f7fa;padding:6px 12px;border-radius:8px;display:inline-block;margin-bottom:16px}
      .spec-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:16px}
      .spec-card{text-align:center;padding:14px;background:#f0f9ff;border-radius:10px}
      .spec-val{font-size:18px;font-weight:800;color:#0d1b2a}
      .spec-label{font-size:12px;color:#64748b}
      .sh{margin-bottom:32px}
      .sh h2{font-size:28px;letter-spacing:-0.02em;margin:0 0 8px}
      .sh p{font-size:16px;margin:0;color:#475569}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}
      .c4{grid-column:span 4}
      .c7{grid-column:span 7}
      .c5{grid-column:span 5}
      .card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:24px}
      .card h3{margin:0 0 8px;font-size:17px}
      .card p{color:#475569}
      .feature-list{list-style:none;padding:0;margin:0}
      .feature-list li{padding:9px 0;border-bottom:1px solid #f1f5f9;font-size:15px;display:flex;gap:10px;align-items:flex-start}
      .feature-list li:last-child{border-bottom:none}
      .feature-check{font-weight:700;flex-shrink:0;font-size:16px}
      .faq-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:22px}
      .faq-card h3{margin:0 0 8px;font-size:16px}
      .faq-card p{margin:0;font-size:15px;color:#475569}
      .formbox{background:#fff;border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:16px}
      ._form_element{margin-bottom:12px}
      ._form_element input,._form_element textarea{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;color:#0f172a;font-size:14px;font-family:system-ui,-apple-system,sans-serif;padding:10px 12px;width:100%}
      ._submit{border:none;border-radius:8px;font-weight:700;font-size:15px;padding:12px 20px;width:100%;margin-top:8px;cursor:pointer;background:#0097a7;color:#fff}
      ._submit:hover{background:#00838f}
      footer{background:#0f172a;color:#64748b;padding:28px 0;font-size:14px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#475569;line-height:1.6;margin-top:12px;padding-top:12px;border-top:1px solid #1e293b}
      @media(max-width:900px){.product-hero-inner{grid-template-columns:1fr}.c6,.c4,.c7,.c5{grid-column:span 12}.sh h2{font-size:24px}}
      @media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}section{padding:40px 0}.product-hero{padding:28px 0}.product-hero h1{font-size:26px}.price-display{font-size:36px}.card,.faq-card,.formbox{padding:18px}.spec-grid{grid-template-columns:1fr}.footer-inner{flex-direction:column;align-items:center;text-align:center}.footer-links{justify-content:center}}
    </style>
  </head>
  <body>
    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo"><a href="/"><img src="/logo.jpg" alt={site.siteName} onerror="this.style.display='none'" /></a></div>
          <nav class="nav-links" aria-label="Primary">
            <a href="/">Home</a>
            <a href="/comparison">Comparison</a>
            <a href="/news">News</a>
            <a href="/#faq">FAQ</a>
            <a href="/#final-cta">Contact</a>
          </nav>
          <div class="nav-ctas">
            <a class="btn btn-primary" href="#cta">Buy Student Edition</a>
            <button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'"><span></span><span></span><span></span></button>
          </div>
        </div>
        <nav class="mobile-nav" aria-label="Mobile">
          <a href="/">Home</a>
          <a href="/dragon-medical-one">Dragon Medical One</a>
          <a href="/dragon-professional-16">Dragon Professional 16</a>
          <a href="/dragon-professional-anywhere">Dragon Professional Anywhere</a>
          <a href="/dragon-legal">Dragon Legal</a>
          <a href="/dragon-education">Education</a>
          <a href="/comparison">Comparison</a>
          <a href="/news">News</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="product-hero">
        <div class="wrap">
          <div class="breadcrumb"><a href="/">Home</a> > <a href="/comparison">Products</a> > Dragon for Education</div>
          <div class="product-hero-inner">
            <div>
              <div class="spec-badge">Student and Education</div>
              <h1>Dragon Software for Education - Student and Educator Pricing</h1>
              <p>The complete Dragon Professional 16 at a discounted price for students, educators and educational institutions. Dictate essays, assignments, research notes and course materials faster and more accurately than typing. Widely used for accessibility and assistive technology needs.</p>
              <div style="margin-bottom:8px">
                <div class="price-display">$545</div>
                <div class="price-note">AUD inc GST - perpetual licence</div>
              </div>
              <div class="price-save">Save $449 compared to full price ($994)</div>
              <div style="font-size:13px;color:#64748b;margin-bottom:20px;padding:10px 14px;background:#f8fafc;border-radius:8px;border-left:3px solid #e2e8f0">Full version. No feature restrictions. Licensed per user. Install on up to 2 PCs.</div>
              <div style="display:flex;gap:12px;flex-wrap:wrap">
                <a class="btn btn-primary btn-lg" href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-educational-student" target="_blank" rel="noopener">Buy Student Edition</a>
                <a class="btn" href="#cta" style="border-color:#cbd5e1;color:#334155">Talk to VRA</a>
              </div>
            </div>
            <div>
              <div class="spec-grid">
                <div class="spec-card"><div class="spec-val">$545</div><div class="spec-label">Student price AUD</div></div>
                <div class="spec-card"><div class="spec-val">Up to 2</div><div class="spec-label">PC installs</div></div>
                <div class="spec-card"><div class="spec-val">Perpetual</div><div class="spec-label">Own it forever</div></div>
              </div>
              {imgSrc("feature-professional") && (
                <div style="border-radius:16px;overflow:hidden;margin-top:16px;box-shadow:0 16px 48px rgba(0,0,0,.12)">
                  <img src={imgSrc("feature-professional")} alt="Student using Dragon Professional speech recognition software" loading="eager" decoding="async" />
                </div>
              )}
            </div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <div class="sh">
                <h2>What students and educators get</h2>
                <p>The full Dragon Professional 16 - no restrictions, no missing features.</p>
              </div>
              <div class="card">
                <ul class="feature-list">
                  <li><span class="feature-check">&#10003;</span>Full Dragon Professional 16 - identical to the $994 version</li>
                  <li><span class="feature-check">&#10003;</span>Real-time dictation into Word, Google Docs, email and any Windows application</li>
                  <li><span class="feature-check">&#10003;</span>Transcribe single-speaker audio recordings (MP3, WAV, WMA, DSS, DS2)</li>
                  <li><span class="feature-check">&#10003;</span>Custom vocabulary - add subject-specific terms, names and abbreviations</li>
                  <li><span class="feature-check">&#10003;</span>AutoText shortcuts - speak a phrase to insert a full paragraph or citation template</li>
                  <li><span class="feature-check">&#10003;</span>Voice macros to automate repetitive formatting and editing tasks</li>
                  <li><span class="feature-check">&#10003;</span>Hands-free PC control - navigate, click, scroll and select by voice</li>
                  <li><span class="feature-check">&#10003;</span>Works offline after installation and activation</li>
                  <li><span class="feature-check">&#10003;</span>Windows 10 and Windows 11 compatible</li>
                  <li><span class="feature-check">&#10003;</span>Perpetual licence - pay once, own it for your entire degree and beyond</li>
                </ul>
              </div>
            </div>
            <div class="c5">
              <div class="card" style="margin-top:52px;background:#0d1b2a;color:white;border-color:#0d1b2a">
                <h3 style="color:white;margin:0 0 16px">Who qualifies</h3>
                <div style="background:rgba(255,255,255,.08);border-radius:12px;padding:16px;margin-bottom:10px">
                  <div style="color:#0097a7;font-weight:700;margin-bottom:4px;font-size:15px">University and TAFE students</div>
                  <div style="font-size:14px;color:#cbd5e1">Currently enrolled students at accredited Australian institutions.</div>
                </div>
                <div style="background:rgba(255,255,255,.08);border-radius:12px;padding:16px;margin-bottom:10px">
                  <div style="color:#0097a7;font-weight:700;margin-bottom:4px;font-size:15px">Teachers and academic staff</div>
                  <div style="font-size:14px;color:#cbd5e1">Educators at schools, universities and registered training organisations.</div>
                </div>
                <div style="background:rgba(255,255,255,.08);border-radius:12px;padding:16px">
                  <div style="color:#0097a7;font-weight:700;margin-bottom:4px;font-size:15px">Accessibility and assistive technology</div>
                  <div style="font-size:14px;color:#cbd5e1">Students and staff using Dragon for dyslexia, RSI, vision impairment or other accessibility needs.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh">
            <h2>Common use cases in education</h2>
          </div>
          <div class="grid">
            <div class="card c4"><h3>Essay and assignment writing</h3><p>Dictate essays, reports and assignments at up to 160 words per minute. Edit and format by voice. Significantly reduces writing time for long-form academic work.</p></div>
            <div class="card c4"><h3>Accessibility and assistive tech</h3><p>Dragon is widely used by students with dyslexia, RSI, cerebral palsy, vision impairment and other conditions. Full hands-free PC control including navigation, mouse control and application switching.</p></div>
            <div class="card c4"><h3>Research and note-taking</h3><p>Transcribe recorded lectures and research interviews (single speaker). Create research notes by voice. Build custom vocabulary for your specific field of study.</p></div>
            <div class="card c4"><h3>Course material creation</h3><p>Educators can dictate lecture notes, course outlines, feedback and assessment comments. AutoText shortcuts make repeated feedback phrases instant.</p></div>
            <div class="card c4"><h3>NDIS and disability support</h3><p>Dragon is commonly funded through NDIS assistive technology plans and university disability services. Contact us for documentation to support funding applications.</p></div>
            <div class="card c4"><h3>Language and ESL support</h3><p>Students can use Dragon to practise pronunciation and spoken English. Dragon supports Australian, UK, US, Canadian, New Zealand and Indian English variants.</p></div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>Frequently asked questions</h2></div>
          <div class="grid">
            <div class="faq-card c6"><h3>Is the Student Edition the full version?</h3><p>Yes. The Student Edition is the complete Dragon Professional 16 with no feature restrictions. The only difference from the standard perpetual licence is the discounted price.</p></div>
            <div class="faq-card c6"><h3>Do I need to prove student or educator status?</h3><p>Contact Voice Recognition Australia when purchasing for specific eligibility requirements and any documentation needed.</p></div>
            <div class="faq-card c6"><h3>Can Dragon help with dyslexia?</h3><p>Yes. Dragon is widely used as an assistive technology tool for students with dyslexia. Dictating rather than typing removes the spelling barrier, and Dragon can read text back aloud to assist with proofreading.</p></div>
            <div class="faq-card c6"><h3>Can NDIS fund Dragon software?</h3><p>Dragon is commonly included in NDIS assistive technology plans. Contact Voice Recognition Australia for supporting documentation and quotes formatted for NDIS submissions.</p></div>
            <div class="faq-card c6"><h3>Does it work on Mac?</h3><p>Dragon Professional 16 is Windows only (Windows 10 and 11). There is no Mac version. Nuance discontinued Dragon for Mac.</p></div>
            <div class="faq-card c6"><h3>Can I keep using it after I graduate?</h3><p>Yes. The Student Edition is a perpetual licence - you own it permanently. It continues to work after you graduate or leave your educational institution.</p></div>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh"><h2>Other Dragon products</h2></div>
          <div style="display:flex;flex-wrap:wrap;gap:10px">
            <a href="/dragon-medical-one" style="padding:8px 16px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Medical One</a>
            <a href="/dragon-professional-16" style="padding:8px 16px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Professional 16</a>
            <a href="/dragon-professional-anywhere" style="padding:8px 16px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Professional Anywhere</a>
            <a href="/dragon-legal" style="padding:8px 16px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Legal</a>
          </div>
          <div style="margin-top:16px"><a class="btn btn-primary" href="/comparison">Compare all products</a></div>
        </div>
      </section>

      <section id="cta" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <h2 style="color:white;font-size:28px;margin:0 0 12px">Questions about Dragon for education?</h2>
              <p style="color:#94a3b8;margin:0 0 20px">Whether you are a student, educator, disability support officer or IT department, we can help you choose the right Dragon product and assist with NDIS or institutional procurement.</p>
              <ul style="color:#94a3b8;margin:0;padding-left:20px;line-height:2.2;font-size:15px">
                <li>Student, educator or institution</li>
                <li>Accessibility or assistive technology needs</li>
                <li>NDIS funding documentation required</li>
                <li>Volume licensing for departments</li>
              </ul>
            </div>
            <div class="c5">
              <div class="formbox">
                <div style="font-weight:800;font-size:20px;color:#0f172a">Get in touch</div>
                <div style="color:#475569;font-size:15px;margin-bottom:4px">Local Australian support. Fast response.</div>
                <form method="POST" action="https://voicerecognition.activehosted.com/proc.php" novalidate>
                  <input type="hidden" name="u" value={site.form.hiddenU} />
                  <input type="hidden" name="f" value={site.form.hiddenF} />
                  <input type="hidden" name="s" />
                  <input type="hidden" name="c" value="0" />
                  <input type="hidden" name="m" value="0" />
                  <input type="hidden" name="act" value="sub" />
                  <input type="hidden" name="v" value="2" />
                  <input type="hidden" name="or" value={site.form.hiddenOr} />
                  <div class="_form_element"><input type="text" name="firstname" placeholder="Your Name" required /></div>
                  <div class="_form_element"><input type="text" name="email" placeholder="Your Email" required /></div>
                  <div class="_form_element"><input type="text" name="phone" placeholder="Your Phone Number" /></div>
                  <div class="_form_element"><input type="text" name="field[35]" placeholder="University / School / Organisation" /></div>
                  <div class="_form_element"><textarea name="field[18]" placeholder="Student, educator or institution? Any accessibility needs?"></textarea></div>
                  <button class="_submit" type="submit">{site.form.submitText}</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">{site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}</div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>
