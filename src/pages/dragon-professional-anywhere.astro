---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";
const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";
function imgSrc(key) { const e = manifest[key]; if (!e?.r2Key || !R2_BASE) return ""; return `${R2_BASE.replace(/\/$/, "")}/${e.r2Key}`; }
function imgAlt(key) { return manifest[key]?.altText || ""; }
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dragon Professional Anywhere Australia | Cloud Speech Recognition for Enterprise</title>
    <meta name="description" content="Dragon Professional Anywhere - cloud-based speech recognition for enterprise. Virtual desktop and Citrix support. Centralised management via Nuance Management Centre. Contact Voice Recognition Australia." />
    <link rel="canonical" href={`${site.domain}/dragon-professional-anywhere`} />
    <script define:vars={{ c }}>
      const css = `.btn-primary{background:${c.accent};border-color:${c.accent};color:#fff}.btn-primary:hover{background:${c.accentHover};border-color:${c.accentHover}}.dark-bg{background:${c.primary};color:white}.neutral-bg{background:${c.neutral}}.feature-check{color:${c.accent}}.spec-badge{background:${c.accent};color:#fff}.nav-links a:hover,.dropdown-toggle:hover{color:${c.accent}}.dropdown-menu{border-top:2px solid ${c.accent}}`;
      const el=document.createElement('style');el.textContent=css;document.head.appendChild(el);
    </script>
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#0f172a;line-height:1.6}a{color:inherit;text-decoration:none}img{max-width:100%;display:block}.wrap{max-width:1080px;margin:0 auto;padding:0 24px}header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}.nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}.logo img{height:40px;width:auto}.nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155;align-items:center}.dropdown{position:relative}.dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap}.dropdown-toggle svg{transition:transform .15s}.dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}.dropdown-menu{display:none;position:absolute;top:100%;left:0;background:#fff;border:1px solid #e2e8f0;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.1);min-width:240px;padding:8px 0 6px;z-index:200}.dropdown:hover .dropdown-menu{display:block}.dropdown-menu a{display:block;padding:10px 16px;font-size:14px;font-weight:500;color:#334155;transition:background .1s}.dropdown-menu a:hover{background:#e0f7fa;color:#006064}.nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}.btn{display:inline-flex;align-items:center;justify-content:center;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}.btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}.hamburger span{display:block;width:22px;height:2px;background:#334155;border-radius:2px}.mobile-nav{display:none;padding:12px 0 8px;border-top:1px solid #e2e8f0}.mobile-nav a{display:block;padding:10px 0;font-size:15px;font-weight:500;color:#334155;border-bottom:1px solid #f1f5f9}section{padding:48px 0}.breadcrumb{font-size:13px;color:#64748b;margin-bottom:18px}.breadcrumb a{color:#0097a7;font-weight:500}.product-hero{padding:40px 0 36px}.product-hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}.product-hero h1{font-size:32px;line-height:1.1;margin:0 0 12px;letter-spacing:-0.03em}.product-hero p{font-size:15px;line-height:1.7;margin:0 0 20px;color:#475569}.spec-badge{display:inline-block;font-size:11px;font-weight:700;padding:4px 12px;border-radius:999px;margin-bottom:12px;text-transform:uppercase;letter-spacing:.05em}.spec-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:14px}.spec-card{text-align:center;padding:12px;background:#f0f9ff;border-radius:10px}.spec-val{font-size:16px;font-weight:800;color:#0d1b2a}.spec-label{font-size:11px;color:#64748b}.sh{margin-bottom:28px}.sh h2{font-size:26px;letter-spacing:-0.02em;margin:0 0 6px}.sh p{font-size:15px;margin:0;color:#475569}.grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}.c6{grid-column:span 6}.c4{grid-column:span 4}.c7{grid-column:span 7}.c5{grid-column:span 5}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px}.card h3{margin:0 0 6px;font-size:16px}.card p{color:#475569;font-size:14px}.feature-list{list-style:none;padding:0;margin:0}.feature-list li{padding:8px 0;border-bottom:1px solid #f1f5f9;font-size:14px;display:flex;gap:8px;align-items:flex-start}.feature-list li:last-child{border-bottom:none}.feature-check{font-weight:700;flex-shrink:0;font-size:15px}.faq-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px}.faq-card h3{margin:0 0 6px;font-size:15px}.faq-card p{margin:0;font-size:14px;color:#475569}.formbox{background:#fff;border-radius:14px;padding:24px;display:flex;flex-direction:column;gap:14px}._form_element{margin-bottom:10px}._form_element input,._form_element textarea{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;color:#0f172a;font-size:14px;font-family:system-ui,-apple-system,sans-serif;padding:10px 12px;width:100%}._submit{border:none;border-radius:8px;font-weight:700;font-size:15px;padding:12px 20px;width:100%;margin-top:8px;cursor:pointer;background:#0097a7;color:#fff}._submit:hover{background:#00838f}footer{background:#0f172a;color:#64748b;padding:24px 0;font-size:13px}.footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}.footer-links{display:flex;gap:18px}.footer-links a:hover{color:white}.footer-disclaimer{font-size:11px;color:#475569;line-height:1.6;margin-top:10px;padding-top:10px;border-top:1px solid #1e293b}@media(max-width:900px){.product-hero-inner{grid-template-columns:1fr}.c6,.c4,.c7,.c5{grid-column:span 12}.sh h2{font-size:22px}}@media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}section{padding:36px 0}.product-hero{padding:24px 0}.product-hero h1{font-size:24px}.card,.faq-card,.formbox{padding:16px}.spec-grid{grid-template-columns:1fr}.footer-inner{flex-direction:column;align-items:center;text-align:center}.footer-links{justify-content:center}}
    </style>
  </head>
  <body>
    <header><div class="wrap"><div class="nav"><div class="logo"><a href="/"><img src="/logo.jpg" alt={site.siteName} onerror="this.style.display='none'" /></a></div><nav class="nav-links" aria-label="Primary">{site.navDropdown && (<div class="dropdown"><span class="dropdown-toggle">{site.navDropdown.label}<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span><div class="dropdown-menu">{site.navDropdown.items?.map((item) => <a href={item.url}>{item.label}</a>)}</div></div>)}{site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}</nav><div class="nav-ctas"><a class="btn btn-primary" href="https://www.voicerecognition.com.au/products/dragon-professional-anywhere" target="_blank" rel="noopener">Buy Now</a><button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'"><span></span><span></span><span></span></button></div></div><nav class="mobile-nav" aria-label="Mobile"><a href="/">Home</a>{site.navDropdown?.items?.map((item) => <a href={item.url}>{item.label}</a>)}<a href="/comparison">Comparison</a><a href="/news">News</a></nav></div></header>

    <main>
      <section class="product-hero">
        <div class="wrap">
          <div class="breadcrumb"><a href="/">Home</a> > <a href="/comparison">Products</a> > Dragon Professional Anywhere</div>
          <div class="product-hero-inner">
            <div>
              <div class="spec-badge">Cloud - Enterprise</div>
              <h1>Dragon Professional Anywhere - Cloud Speech Recognition for Enterprise</h1>
              <p>Cloud-native speech recognition designed for enterprise and distributed teams. Always up to date, works in virtual desktop and Citrix environments, with centralised administration via Nuance Management Centre. Ideal for organisations deploying Dragon across multiple users and locations.</p>
              <div style="margin-bottom:6px"><div style="font-size:32px;font-weight:800;color:#0d1b2a">Contact us for pricing</div><div style="font-size:13px;color:#64748b">Per user per year - volume pricing available</div></div>
              <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:18px;align-items:center">
                <a class="btn btn-primary btn-lg" href="https://www.voicerecognition.com.au/products/dragon-professional-anywhere" target="_blank" rel="noopener">Buy Now</a>
                <a class="btn btn-lg" href="#cta" style="border-color:#cbd5e1;color:#334155">Contact Us</a>
              </div>
            </div>
            <div>
              <div class="spec-grid">
                <div class="spec-card"><div class="spec-val">Cloud</div><div class="spec-label">Always up to date</div></div>
                <div class="spec-card"><div class="spec-val">Citrix</div><div class="spec-label">VDI supported</div></div>
                <div class="spec-card"><div class="spec-val">NMC</div><div class="spec-label">Central admin</div></div>
              </div>
              {imgSrc("hero-anywhere") && (<div style="border-radius:14px;overflow:hidden;margin-top:14px;box-shadow:0 12px 40px rgba(0,0,0,.12)"><img src={imgSrc("hero-anywhere")} alt={imgAlt("hero-anywhere")} loading="eager" decoding="async" /></div>)}
            </div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>What Dragon Professional Anywhere includes</h2><p>Enterprise-grade cloud speech recognition with centralised management.</p></div>
          <div class="card">
            <ul class="feature-list">
              <li><span class="feature-check">&#10003;</span>Cloud-based - always the latest version, no local installation management</li>
              <li><span class="feature-check">&#10003;</span>Anchor dictation - dictate into any Windows application from a floating dictation box</li>
              <li><span class="feature-check">&#10003;</span>Virtual desktop and thin client support (Citrix, RDP environments)</li>
              <li><span class="feature-check">&#10003;</span>Centralised administration via Nuance Management Centre (NMC)</li>
              <li><span class="feature-check">&#10003;</span>Voice profile roaming - your profile follows you across devices</li>
              <li><span class="feature-check">&#10003;</span>Dragon Anywhere Mobile app included for iOS and Android dictation</li>
              <li><span class="feature-check">&#10003;</span>Custom vocabulary, AutoText, and voice commands</li>
              <li><span class="feature-check">&#10003;</span>Microsoft 365 and Microsoft Teams integration</li>
              <li><span class="feature-check">&#10003;</span>Usage reporting and licence management for IT administrators</li>
            </ul>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh"><h2>When to choose Dragon Professional Anywhere over Dragon Professional 16</h2></div>
          <div class="grid">
            <div class="card c6"><h3>Choose Anywhere if you need...</h3><p>Cloud deployment with no local installation, Citrix or virtual desktop environments, centralised user management, voice profile roaming across devices, or automatic updates without IT involvement.</p></div>
            <div class="card c6"><h3>Choose Professional 16 if you need...</h3><p>Offline operation after activation, locally installed software with no internet dependency, one-time perpetual purchase, or full voice command and macro capabilities in a single-user desktop environment.</p></div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>Frequently asked questions</h2></div>
          <div class="grid">
            <div class="faq-card c6"><h3>Does Dragon Professional Anywhere work offline?</h3><p>No. Dragon Professional Anywhere is a cloud-native product that requires an internet connection to function. For offline operation, Dragon Professional 16 is the appropriate choice.</p></div>
            <div class="faq-card c6"><h3>Does it support Citrix and virtual desktops?</h3><p>Yes. Dragon Professional Anywhere is designed for virtual desktop infrastructure including Citrix and Remote Desktop Protocol (RDP) environments. Contact us for deployment guidance.</p></div>
            <div class="faq-card c6"><h3>What is the Nuance Management Centre?</h3><p>NMC is a server-based administration tool for IT teams to centrally manage Dragon deployments - assigning licences, managing user profiles, distributing custom vocabulary, and monitoring usage across the organisation.</p></div>
            <div class="faq-card c6"><h3>Can I use it on mobile devices?</h3><p>Yes. Dragon Professional Anywhere includes the Dragon Anywhere Mobile companion app for iOS and Android, allowing you to dictate on the go with the same voice profile.</p></div>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh"><h2>Other Dragon products</h2></div>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            <a href="/dragon-medical-one" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Medical One</a>
            <a href="/dragon-professional-16" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Professional 16</a>
            <a href="/dragon-legal" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Legal</a>
            <a href="/dragon-education" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon for Education</a>
          </div>
          <div style="margin-top:14px"><a class="btn btn-primary" href="/comparison">Compare all products</a></div>
        </div>
      </section>

      <section id="cta" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <h2 style="color:white;font-size:26px;margin:0 0 10px">Ready to deploy Dragon Professional Anywhere?</h2>
              <p style="color:#94a3b8;margin:0 0 16px;font-size:14px">Voice Recognition Australia has experience deploying Dragon Anywhere in government departments, legal chambers, and enterprise environments. Tell us about your infrastructure and we will provide a tailored recommendation.</p>
              <ul style="color:#94a3b8;margin:0;padding-left:20px;line-height:2;font-size:14px"><li>Number of users and locations</li><li>Virtual desktop environment (Citrix, RDP, other)</li><li>Current dictation or documentation workflow</li><li>IT management and procurement requirements</li></ul>
            </div>
            <div class="c5">
              <div class="formbox">
                <div style="font-weight:800;font-size:18px;color:#0f172a">Get in touch</div>
                <div style="color:#475569;font-size:14px;margin-bottom:2px">Local Australian support. Fast response.</div>
                <form method="POST" action="https://voicerecognition.activehosted.com/proc.php" novalidate>
                  <input type="hidden" name="u" value={site.form.hiddenU} /><input type="hidden" name="f" value={site.form.hiddenF} /><input type="hidden" name="s" /><input type="hidden" name="c" value="0" /><input type="hidden" name="m" value="0" /><input type="hidden" name="act" value="sub" /><input type="hidden" name="v" value="2" /><input type="hidden" name="or" value={site.form.hiddenOr} />
                  <div class="_form_element"><input type="text" name="firstname" placeholder="Your Name" required /></div>
                  <div class="_form_element"><input type="text" name="email" placeholder="Your Email" required /></div>
                  <div class="_form_element"><input type="text" name="phone" placeholder="Your Phone Number" /></div>
                  <div class="_form_element"><input type="text" name="field[21]" placeholder="Number of Users" /></div>
                  <div class="_form_element"><input type="text" name="field[35]" placeholder="Organisation" /></div>
                  <div class="_form_element"><textarea name="field[18]" placeholder="Your infrastructure (Citrix, RDP, etc) and deployment needs"></textarea></div>
                  <button class="_submit" type="submit">{site.form.submitText}</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <footer><div class="wrap"><div class="footer-inner"><div>&copy; {year} {site.siteName}</div><div class="footer-links">{site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}</div></div><div class="footer-disclaimer">{site.branding.footerDisclaimer}</div></div></footer>
  </body>
</html>
