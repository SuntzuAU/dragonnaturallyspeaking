---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";
const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";
function imgSrc(key) { const e = manifest[key]; if (!e?.r2Key || !R2_BASE) return ""; return `${R2_BASE.replace(/\/$/, "")}/${e.r2Key}`; }
function imgAlt(key) { return manifest[key]?.altText || ""; }
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dragon Legal Australia | Speech Recognition for Law Firms and Legal Professionals</title>
    <meta name="description" content="Dragon Legal Anywhere - cloud-based speech recognition with built-in legal vocabulary. Designed for Australian law firms, barristers, and legal professionals. Contact Voice Recognition Australia." />
    <link rel="canonical" href={`${site.domain}/dragon-legal`} />
    <script define:vars={{ c }}>
      const css = `.btn-primary{background:${c.accent};border-color:${c.accent};color:#fff}.btn-primary:hover{background:${c.accentHover};border-color:${c.accentHover}}.dark-bg{background:${c.primary};color:white}.neutral-bg{background:${c.neutral}}.feature-check{color:${c.accent}}.spec-badge{background:${c.accent};color:#fff}.nav-links a:hover,.dropdown-toggle:hover{color:${c.accent}}.dropdown-menu{border-top:2px solid ${c.accent}}`;
      const el=document.createElement('style');el.textContent=css;document.head.appendChild(el);
    </script>
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#0f172a;line-height:1.6}a{color:inherit;text-decoration:none}img{max-width:100%;display:block}.wrap{max-width:1080px;margin:0 auto;padding:0 24px}header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}.nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}.logo img{height:40px;width:auto}.nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155;align-items:center}.dropdown{position:relative}.dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap}.dropdown-toggle svg{transition:transform .15s}.dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}.dropdown-menu{display:none;position:absolute;top:100%;left:0;background:#fff;border:1px solid #e2e8f0;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.1);min-width:240px;padding:8px 0 6px;z-index:200}.dropdown:hover .dropdown-menu{display:block}.dropdown-menu a{display:block;padding:10px 16px;font-size:14px;font-weight:500;color:#334155;transition:background .1s}.dropdown-menu a:hover{background:#e0f7fa;color:#006064}.nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}.btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}.btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}.hamburger span{display:block;width:22px;height:2px;background:#334155;border-radius:2px}.mobile-nav{display:none;padding:12px 0 8px;border-top:1px solid #e2e8f0}.mobile-nav a{display:block;padding:10px 0;font-size:15px;font-weight:500;color:#334155;border-bottom:1px solid #f1f5f9}section{padding:48px 0}.breadcrumb{font-size:13px;color:#64748b;margin-bottom:18px}.breadcrumb a{color:#0097a7;font-weight:500}.product-hero{padding:40px 0 36px}.product-hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}.product-hero h1{font-size:32px;line-height:1.1;margin:0 0 12px;letter-spacing:-0.03em}.product-hero p{font-size:15px;line-height:1.7;margin:0 0 20px;color:#475569}.spec-badge{display:inline-block;font-size:11px;font-weight:700;padding:4px 12px;border-radius:999px;margin-bottom:12px;text-transform:uppercase;letter-spacing:.05em}.spec-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:14px}.spec-card{text-align:center;padding:12px;background:#f0f9ff;border-radius:10px}.spec-val{font-size:16px;font-weight:800;color:#0d1b2a}.spec-label{font-size:11px;color:#64748b}.sh{margin-bottom:28px}.sh h2{font-size:26px;letter-spacing:-0.02em;margin:0 0 6px}.sh p{font-size:15px;margin:0;color:#475569}.grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}.c6{grid-column:span 6}.c4{grid-column:span 4}.c7{grid-column:span 7}.c5{grid-column:span 5}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px}.card h3{margin:0 0 6px;font-size:16px}.card p{color:#475569;font-size:14px}.feature-list{list-style:none;padding:0;margin:0}.feature-list li{padding:8px 0;border-bottom:1px solid #f1f5f9;font-size:14px;display:flex;gap:8px;align-items:flex-start}.feature-list li:last-child{border-bottom:none}.feature-check{font-weight:700;flex-shrink:0;font-size:15px}.faq-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px}.faq-card h3{margin:0 0 6px;font-size:15px}.faq-card p{margin:0;font-size:14px;color:#475569}.formbox{background:#fff;border-radius:14px;padding:24px;display:flex;flex-direction:column;gap:14px}._form_element{margin-bottom:10px}._form_element input,._form_element textarea{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;color:#0f172a;font-size:14px;font-family:system-ui,-apple-system,sans-serif;padding:10px 12px;width:100%}._submit{border:none;border-radius:8px;font-weight:700;font-size:15px;padding:12px 20px;width:100%;margin-top:8px;cursor:pointer;background:#0097a7;color:#fff}._submit:hover{background:#00838f}footer{background:#0f172a;color:#64748b;padding:24px 0;font-size:13px}.footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}.footer-links{display:flex;gap:18px}.footer-links a:hover{color:white}.footer-disclaimer{font-size:11px;color:#475569;line-height:1.6;margin-top:10px;padding-top:10px;border-top:1px solid #1e293b}@media(max-width:900px){.product-hero-inner{grid-template-columns:1fr}.c6,.c4,.c7,.c5{grid-column:span 12}.sh h2{font-size:22px}}@media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}section{padding:36px 0}.product-hero{padding:24px 0}.product-hero h1{font-size:24px}.card,.faq-card,.formbox{padding:16px}.spec-grid{grid-template-columns:1fr}.footer-inner{flex-direction:column;align-items:center;text-align:center}.footer-links{justify-content:center}}
    </style>
  </head>
  <body>
    <header><div class="wrap"><div class="nav"><div class="logo"><a href="/"><img src="/logo.jpg" alt={site.siteName} onerror="this.style.display='none'" /></a></div><nav class="nav-links" aria-label="Primary">{site.navDropdown && (<div class="dropdown"><span class="dropdown-toggle">{site.navDropdown.label}<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span><div class="dropdown-menu">{site.navDropdown.items?.map((item) => <a href={item.url}>{item.label}</a>)}</div></div>)}{site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}</nav><div class="nav-ctas"><a class="btn btn-primary" href="#cta">Enquire Now</a><button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'"><span></span><span></span><span></span></button></div></div><nav class="mobile-nav" aria-label="Mobile"><a href="/">Home</a>{site.navDropdown?.items?.map((item) => <a href={item.url}>{item.label}</a>)}<a href="/comparison">Comparison</a><a href="/news">News</a></nav></div></header>

    <main>
      <section class="product-hero">
        <div class="wrap">
          <div class="breadcrumb"><a href="/">Home</a> > <a href="/comparison">Products</a> > Dragon Legal</div>
          <div class="product-hero-inner">
            <div>
              <div class="spec-badge">Cloud - Legal Profession</div>
              <h1>Dragon Legal - Speech Recognition for Australian Law Firms</h1>
              <p>Dragon Legal Anywhere is the cloud-based speech recognition platform built specifically for the legal profession. Built-in legal vocabulary covers court terminology, legislation, case law citations, and legal drafting conventions. Cloud-based for law firm deployment with centralised administration.</p>
              <div style="margin-bottom:6px"><div style="font-size:32px;font-weight:800;color:#0d1b2a">Contact us for pricing</div><div style="font-size:13px;color:#64748b">Subscription - volume pricing for chambers and firms</div></div>
              <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:18px">
                <a class="btn btn-primary btn-lg" href="#cta">Get a Quote</a>
                <a class="btn" href="/comparison" style="border-color:#cbd5e1;color:#334155">Compare Products</a>
              </div>
            </div>
            <div>
              <div class="spec-grid">
                <div class="spec-card"><div class="spec-val">Legal</div><div class="spec-label">Built-in vocabulary</div></div>
                <div class="spec-card"><div class="spec-val">Cloud</div><div class="spec-label">Anywhere access</div></div>
                <div class="spec-card"><div class="spec-val">NMC</div><div class="spec-label">Central admin</div></div>
              </div>
              {imgSrc("feature-professional") && (<div style="border-radius:14px;overflow:hidden;margin-top:14px;box-shadow:0 12px 40px rgba(0,0,0,.12)"><img src={imgSrc("feature-professional")} alt="Legal professional using Dragon speech recognition" loading="eager" decoding="async" /></div>)}
            </div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>What Dragon Legal Anywhere includes</h2><p>Everything in Dragon Professional Anywhere, plus legal-specific vocabulary and workflows.</p></div>
          <div class="card">
            <ul class="feature-list">
              <li><span class="feature-check">&#10003;</span>Built-in legal vocabulary - court terminology, legislation, case law citations, legal drafting</li>
              <li><span class="feature-check">&#10003;</span>Cloud-based - dictate from any device, anywhere</li>
              <li><span class="feature-check">&#10003;</span>Custom vocabulary for firm-specific terms, client names, and matter references</li>
              <li><span class="feature-check">&#10003;</span>AutoText for standard clauses, correspondence templates, and court forms</li>
              <li><span class="feature-check">&#10003;</span>Centralised administration via Nuance Management Centre</li>
              <li><span class="feature-check">&#10003;</span>Voice profile roaming across devices</li>
              <li><span class="feature-check">&#10003;</span>Dragon Anywhere Mobile app for dictation on the go</li>
              <li><span class="feature-check">&#10003;</span>Microsoft 365 and document management system integration</li>
            </ul>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh"><h2>Legal workflow applications</h2></div>
          <div class="grid">
            <div class="card c4"><h3>Court document drafting</h3><p>Dictate affidavits, submissions, orders, and pleadings with legal terminology recognised accurately from first use.</p></div>
            <div class="card c4"><h3>Client correspondence</h3><p>Draft letters, emails, and file notes by voice. Use AutoText to insert standard paragraphs and disclaimers instantly.</p></div>
            <div class="card c4"><h3>File notes and attendance records</h3><p>Record attendance notes immediately after client meetings and court appearances. Dictate directly into your practice management system.</p></div>
            <div class="card c4"><h3>Contract review notes</h3><p>Dictate review comments and markup notes while reading contracts on screen. Keeps hands free for document navigation.</p></div>
            <div class="card c4"><h3>Chambers and barristers</h3><p>Barristers can dictate opinions, advices, and submissions from chambers or while travelling with the mobile companion app.</p></div>
            <div class="card c4"><h3>Firm-wide deployment</h3><p>IT administrators manage Dragon Legal across the entire firm via NMC - user provisioning, vocabulary distribution, usage reporting, and licence management.</p></div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>Frequently asked questions</h2></div>
          <div class="grid">
            <div class="faq-card c6"><h3>What is the difference between Dragon Legal and Dragon Professional?</h3><p>Dragon Legal Anywhere includes everything in Dragon Professional Anywhere plus built-in legal vocabulary. It is described by the vendor as Dragon Professional plus specialised legal terminology.</p></div>
            <div class="faq-card c6"><h3>Is there a desktop version of Dragon Legal?</h3><p>Dragon Legal Anywhere is cloud-based. For locally installed desktop use with legal vocabulary, Dragon Professional 16 can be customised with legal terms via custom vocabulary - though this requires manual setup rather than built-in legal dictionaries.</p></div>
            <div class="faq-card c6"><h3>Can it integrate with legal practice management software?</h3><p>Dragon Legal Anywhere works with Windows applications including common legal practice management and document management systems. Contact us to discuss compatibility with your specific software.</p></div>
            <div class="faq-card c6"><h3>How does firm-wide deployment work?</h3><p>Dragon Legal Anywhere is managed via the Nuance Management Centre (NMC). IT teams can provision users, distribute shared vocabulary and AutoText, manage licences, and monitor usage across the firm.</p></div>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh"><h2>Other Dragon products</h2></div>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            <a href="/dragon-medical-one" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Medical One</a>
            <a href="/dragon-professional-16" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Professional 16</a>
            <a href="/dragon-professional-anywhere" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Professional Anywhere</a>
            <a href="/dragon-education" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon for Education</a>
          </div>
          <div style="margin-top:14px"><a class="btn btn-primary" href="/comparison">Compare all products</a></div>
        </div>
      </section>

      <section id="cta" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <h2 style="color:white;font-size:26px;margin:0 0 10px">Ready to deploy Dragon Legal in your firm?</h2>
              <p style="color:#94a3b8;margin:0 0 16px;font-size:14px">Voice Recognition Australia has deployed Dragon in Australian legal chambers, law firms, and government legal departments. Tell us about your practice and we will provide a tailored recommendation and pricing.</p>
              <ul style="color:#94a3b8;margin:0;padding-left:20px;line-height:2;font-size:14px"><li>Number of fee earners and support staff</li><li>Practice management system in use</li><li>Desktop or virtual desktop environment</li><li>Current dictation workflow</li></ul>
            </div>
            <div class="c5">
              <div class="formbox">
                <div style="font-weight:800;font-size:18px;color:#0f172a">Get a quote</div>
                <div style="color:#475569;font-size:14px;margin-bottom:2px">Local Australian support. Fast response.</div>
                <form method="POST" action="https://voicerecognition.activehosted.com/proc.php" novalidate>
                  <input type="hidden" name="u" value={site.form.hiddenU} /><input type="hidden" name="f" value={site.form.hiddenF} /><input type="hidden" name="s" /><input type="hidden" name="c" value="0" /><input type="hidden" name="m" value="0" /><input type="hidden" name="act" value="sub" /><input type="hidden" name="v" value="2" /><input type="hidden" name="or" value={site.form.hiddenOr} />
                  <div class="_form_element"><input type="text" name="firstname" placeholder="Your Name" required /></div>
                  <div class="_form_element"><input type="text" name="email" placeholder="Your Email" required /></div>
                  <div class="_form_element"><input type="text" name="phone" placeholder="Your Phone Number" /></div>
                  <div class="_form_element"><input type="text" name="field[21]" placeholder="Number of Users" /></div>
                  <div class="_form_element"><input type="text" name="field[35]" placeholder="Firm / Chambers Name" /></div>
                  <div class="_form_element"><textarea name="field[18]" placeholder="Practice area and current dictation workflow"></textarea></div>
                  <button class="_submit" type="submit">{site.form.submitText}</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <footer><div class="wrap"><div class="footer-inner"><div>&copy; {year} {site.siteName}</div><div class="footer-links">{site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}</div></div><div class="footer-disclaimer">{site.branding.footerDisclaimer}</div></div></footer>
  </body>
</html>
