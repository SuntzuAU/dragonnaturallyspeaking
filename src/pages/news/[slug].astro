---
import { getCollection } from 'astro:content';
import site from '../../site.config.json';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.filter(p => p.slug !== '_placeholder').map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const R2_BASE = (import.meta.env.PUBLIC_R2_BASE ?? 'https://pub-c7a09e1ddb7c45e6a38fcdca1e4b6897.r2.dev').replace(/\/$/, '');
const imgSrc = (key) => key ? `${R2_BASE}/${key}` : '';

const year = new Date().getFullYear();
const formattedDate = new Date(post.data.date).toLocaleDateString('en-AU', {
  day: 'numeric', month: 'long', year: 'numeric'
});

// Render the markdown, then split it on <h2> boundaries so break images can be
// inserted between body sections instead of being pinned to the top/bottom of
// the article container.
async function renderBodyHtml() {
  // Astro components can't be serialised to a string from within the frontmatter
  // so we use the compiled HTML string that Astro exposes via post.body is not
  // available here; instead, render the Content component through a string
  // transform by delegating to the container's renderToString. However Astro
  // does not expose that cleanly, so we fall back to splitting on the h2 tag
  // in the already-rendered client output. Since we cannot do that, we use a
  // different approach: render the raw markdown body and do the split there.
  return null;
}

// Extract the raw markdown body (everything after the closing frontmatter ---)
const rawBody = post.body || '';

// Split the markdown into sections by h2 (## at start of line).
// Each section except the first includes its leading heading.
function splitSections(md) {
  const lines = md.split('\n');
  const sections = [];
  let current = [];
  for (const line of lines) {
    if (/^##\s+/.test(line) && current.length > 0) {
      sections.push(current.join('\n'));
      current = [line];
    } else {
      current.push(line);
    }
  }
  if (current.length > 0) sections.push(current.join('\n'));
  return sections;
}

const sections = splitSections(rawBody);
const totalSections = sections.length;

// Decide insertion points:
//   break1 after section index 0 (so it sits after the first h2 block)
//   break2 after roughly 2/3 through (but never at the last section boundary)
// If the article has fewer than 3 sections, both images fall back to top/bottom.
const break1After = totalSections >= 2 ? 0 : -1;
const break2After = totalSections >= 4
  ? Math.max(1, Math.floor((totalSections - 1) * 2 / 3))
  : (totalSections >= 3 ? totalSections - 2 : -1);

// We need to render each section as HTML. Astro doesn't give us per-section
// Content components, so we use the marked library... which isn't installed
// by default. Instead we fall back to inserting the break images into the
// markdown body BEFORE Astro renders it, then let Astro's markdown processor
// handle the whole thing in one pass.
function buildInjectedBody() {
  if (break1After === -1 && break2After === -1) return rawBody;
  const out = [];
  for (let i = 0; i < sections.length; i++) {
    out.push(sections[i]);
    if (i === break1After && post.data.breakImage1) {
      out.push('');
      out.push(`<div class="img-break"><img src="${imgSrc(post.data.breakImage1)}" alt="${(post.data.breakImage1Alt || '').replace(/"/g, '&quot;')}" loading="lazy" decoding="async" /></div>`);
      out.push('');
    }
    if (i === break2After && post.data.breakImage2) {
      out.push('');
      out.push(`<div class="img-break"><img src="${imgSrc(post.data.breakImage2)}" alt="${(post.data.breakImage2Alt || '').replace(/"/g, '&quot;')}" loading="lazy" decoding="async" /></div>`);
      out.push('');
    }
  }
  return out.join('\n');
}

// NOTE: We can't re-render modified markdown at build time without re-running
// Astro's compiler. So we keep using <Content /> for the body, and render
// break images via a separate per-section mechanism in the template. To keep
// things simple and robust, we fall back to rendering break1 near the top
// and break2 near the bottom BUT inside the prose container, plus we insert
// a DOM-splitting script for finer placement when h2 tags exist.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} -- {site.siteName}</title>
    <meta name="description" content={post.data.metaDescription} />
    <link rel="canonical" href={`${site.domain}/news/${post.slug}`} />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.metaDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`${site.domain}/news/${post.slug}`} />
    {post.data.heroImage && <meta property="og:image" content={imgSrc(post.data.heroImage)} />}
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:#fff;color:#0f172a;line-height:1.7}
      header{border-bottom:1px solid #e2e8f0;padding:14px 24px;display:flex;align-items:center;justify-content:space-between}
      header a.logo img{height:40px;width:auto;display:block}
      header a.back{font-size:14px;color:#0d1b2a;text-decoration:none;font-weight:600}
      header a.back:hover{text-decoration:underline}
      .hero-img{width:100%;max-height:480px;overflow:hidden;background:#f1f5f9}
      .hero-img img{width:100%;height:480px;object-fit:cover;display:block}
      .article{max-width:760px;margin:0 auto;padding:48px 24px 80px}
      .meta{display:flex;gap:16px;align-items:center;margin-bottom:24px;flex-wrap:wrap}
      .meta-date,.meta-site{font-size:13px;color:#94a3b8}
      h1{font-size:36px;letter-spacing:-0.02em;line-height:1.15;margin:0 0 24px;color:#0f172a}
      .img-break{margin:32px 0;border-radius:14px;overflow:hidden;background:#f1f5f9}
      .img-break img{width:100%;max-height:360px;object-fit:cover;display:block}
      .prose{font-size:16px;color:#334155;line-height:1.8}
      .prose p{margin:0 0 18px}
      .prose h2{font-size:22px;font-weight:700;color:#0d1b2a;margin:40px 0 16px;letter-spacing:-0.01em}
      .prose h3{font-size:17px;font-weight:700;color:#0f172a;margin:24px 0 10px}
      .prose ul,.prose ol{padding-left:24px;margin:0 0 18px}
      .prose li{margin-bottom:6px}
      .prose a{color:#0097a7}
      .prose strong{color:#0f172a}
      .prose blockquote{border-left:3px solid #0097a7;margin:24px 0;padding:12px 20px;background:#e0f7fa;border-radius:0 8px 8px 0}
      .prose blockquote p{margin:0;color:#006064;font-style:italic}
      .cta-strip{background:#0d1b2a;border-radius:14px;padding:32px;margin:48px 0;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
      .cta-strip p{margin:0;color:#cbd5e1;font-size:15px;max-width:500px}
      .cta-strip a{display:inline-block;background:#0097a7;color:#ffffff;font-weight:700;font-size:14px;padding:12px 24px;border-radius:8px;text-decoration:none;white-space:nowrap}
      .cta-strip a:hover{background:#00838f}
      footer{border-top:1px solid #e2e8f0;padding:24px;text-align:center;font-size:13px;color:#94a3b8}
      footer a{color:#0d1b2a;text-decoration:none}
      @media(max-width:600px){
        h1{font-size:24px}
        .hero-img img{height:220px}
        .cta-strip{flex-direction:column;text-align:center}
        .article{padding:28px 16px 60px}
      }
    </style>
  </head>
  <body>
    <header>
      <a class="logo" href="/"><img src="/logo.jpg" alt={site.siteName} onerror="this.style.display='none'" /></a>
      <a class="back" href="/news">All articles</a>
    </header>
    {post.data.heroImage && (
      <div class="hero-img">
        <img src={imgSrc(post.data.heroImage)} alt={post.data.heroImageAlt ?? post.data.title} loading="eager" decoding="async" />
      </div>
    )}
    <article class="article">
      <div class="meta">
        <span class="meta-date">{formattedDate}</span>
        <span class="meta-site">{site.siteName}</span>
      </div>
      <h1>{post.data.title}</h1>
      <div class="prose" id="article-prose" data-break1={post.data.breakImage1 ? imgSrc(post.data.breakImage1) : ''} data-break1-alt={post.data.breakImage1Alt ?? ''} data-break2={post.data.breakImage2 ? imgSrc(post.data.breakImage2) : ''} data-break2-alt={post.data.breakImage2Alt ?? ''}>
        <Content />
      </div>
      <div class="cta-strip">
        <p>Ready to explore Dragon speech recognition for your organisation? Get a free trial and tailored recommendation.</p>
        <a href="/#final-cta">Enquire Now</a>
      </div>
    </article>
    <footer>
      <a href="/">{site.siteName}</a> --
      <a href="/news">News</a> --
      <a href="/privacy">Privacy</a> --
      &copy; {year} Voice Recognition Australia
    </footer>
    <script is:inline>
      // Insert break images inline between body sections so they appear within
      // the article flow rather than at the article container edges. Break1
      // goes after the first h2 section (i.e. before the second h2), break2
      // goes after roughly two-thirds of the h2 sections.
      (function () {
        var prose = document.getElementById('article-prose');
        if (!prose) return;

        var break1Src = prose.getAttribute('data-break1');
        var break1Alt = prose.getAttribute('data-break1-alt') || '';
        var break2Src = prose.getAttribute('data-break2');
        var break2Alt = prose.getAttribute('data-break2-alt') || '';

        if (!break1Src && !break2Src) return;

        var h2s = prose.querySelectorAll('h2');
        if (h2s.length === 0) return;

        function makeBreak(src, alt) {
          var wrap = document.createElement('div');
          wrap.className = 'img-break';
          var img = document.createElement('img');
          img.src = src;
          img.alt = alt;
          img.loading = 'lazy';
          img.decoding = 'async';
          wrap.appendChild(img);
          return wrap;
        }

        // break1: insert BEFORE the second h2 (i.e. after the first section).
        // If there is only one h2, insert after the first section's last child.
        if (break1Src) {
          var target1 = h2s.length >= 2 ? h2s[1] : null;
          if (target1) {
            prose.insertBefore(makeBreak(break1Src, break1Alt), target1);
          } else {
            prose.appendChild(makeBreak(break1Src, break1Alt));
          }
        }

        // break2: insert BEFORE the h2 at roughly 2/3 through the sections.
        // If too few sections, insert near the end of prose.
        if (break2Src) {
          if (h2s.length >= 4) {
            var idx = Math.max(2, Math.floor((h2s.length - 1) * 2 / 3));
            var target2 = h2s[idx];
            if (target2) {
              prose.insertBefore(makeBreak(break2Src, break2Alt), target2);
            } else {
              prose.appendChild(makeBreak(break2Src, break2Alt));
            }
          } else if (h2s.length === 3) {
            prose.insertBefore(makeBreak(break2Src, break2Alt), h2s[2]);
          } else {
            prose.appendChild(makeBreak(break2Src, break2Alt));
          }
        }
      })();
    </script>
  </body>
</html>
