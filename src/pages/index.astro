---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";
import ACForm from "../components/ACForm.astro";

const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) {
  return manifest[key]?.altText || key;
}

const c = site.colours;
const formId = site.form.id;

// --- Schema markup ---
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": site.faqs?.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  })) || []
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Voice Recognition Australia",
  "url": "https://www.voicerecognition.com.au",
  "description": "Australia's longest-serving authorised Dragon reseller. 25+ years deploying speech recognition across healthcare, legal, government and enterprise.",
  "foundingDate": "2000",
  "sameAs": [
    "https://dragonprofessional16.com.au",
    "https://dragonnaturallyspeaking.com.au",
    "https://dragonmedicalone.au",
    "https://dictationsolutions.com.au",
    "https://cloudprinting.au",
    "https://speechrecognition.cloud",
    "https://pdfsoftware.com.au"
  ]
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.siteName,
  "url": site.domain,
  "publisher": {
    "@type": "Organization",
    "name": "Voice Recognition Australia"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
 <title>{site.branding.metaTitle ?? site.siteName}</title>
    <meta name="description" content={site.branding.metaDesc ?? site.branding.subheadline} />
    <link rel="canonical" href={site.domain} />

    <!-- Schema markup -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />

    {site.googleAnalyticsId && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.googleAnalyticsId}`}></script>
      <script define:vars={{ gaId: site.googleAnalyticsId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}

    <script define:vars={{ c, formId }}>
      const css = `
        body { background: ${c.background}; color: ${c.text}; }
        .nav-links a:hover, .dropdown-toggle:hover { color: ${c.accent}; }
        .dropdown-menu { border-top: 2px solid ${c.accent}; }
        .btn-primary { background: ${c.accent}; border-color: ${c.accent}; color: #fff; }
        .btn-primary:hover { background: ${c.accentHover}; border-color: ${c.accentHover}; }
        .btn-secondary { color: ${c.primary}; }
        .btn-secondary:hover { border-color: ${c.primary}; }
        .neutral-bg { background: ${c.neutral}; }
        .dark-bg { background: ${c.primary}; color: white; }
        .stats-bar { background: ${c.primary}; }
        .stats-savings { color: ${c.accent}; }
        .sh p { color: ${c.muted}; }
        .card p { color: ${c.muted}; }
        .hero p { color: ${c.muted}; }
        .pricing-card.highlight { border-color: ${c.accent}; box-shadow: 0 8px 32px rgba(0,151,167,.15); }
        .pricing-badge { background: ${c.accent}; color: #fff; }
        .pricing-price { color: ${c.primary}; }
        .tco-table tr.winner td { background: #e0f7fa; font-weight: 700; color: ${c.primary}; }
        .step-num { background: ${c.accent}; color: #fff; }
        .edition-name { color: ${c.accent}; font-weight: 700; margin-bottom: 4px; font-size: 15px; }
      `;
      const el = document.createElement('style');
      el.textContent = css;
      document.head.appendChild(el);
    </script>

    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#0f172a;line-height:1.6}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:40px;width:auto}
      .nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155;align-items:center}
      .dropdown{position:relative}
      .dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap}
      .dropdown-toggle svg{transition:transform .15s}
      .dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}
      .dropdown-menu{display:none;position:absolute;top:100%;left:0;background:#fff;border:1px solid #e2e8f0;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.1);min-width:240px;padding:8px 0 6px;z-index:200}
      .dropdown:hover .dropdown-menu{display:block}
      .dropdown-menu a{display:block;padding:10px 16px;font-size:14px;font-weight:500;color:#334155;transition:background .1s}
      .dropdown-menu a:hover{background:#e0f7fa;color:#006064}
      .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}
      .btn-secondary{background:white;border-color:#cbd5e1}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
      .hamburger span{display:block;width:22px;height:2px;background:#334155;border-radius:2px}
      .mobile-nav{display:none;padding:12px 0 8px;border-top:1px solid #e2e8f0}
      .mobile-nav a{display:block;padding:10px 0;font-size:15px;font-weight:500;color:#334155;border-bottom:1px solid #f1f5f9}
      .mobile-nav a:last-child{border-bottom:none}
      section{padding:48px 0}
      .hero{padding:56px 0 40px}
      .hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
      .hero-pill{display:inline-flex;align-items:center;background:#e0f7fa;border:1px solid #b2ebf2;border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;color:#006064;margin-bottom:14px}
      .hero h1{font-size:38px;line-height:1.1;margin:0 0 14px;letter-spacing:-0.03em}
      .hero p{font-size:16px;margin:0 0 24px;line-height:1.7}
      .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
      .hero-img{border-radius:16px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;box-shadow:0 24px 64px rgba(0,0,0,.18)}
      .hero-img img{width:100%;height:100%;object-fit:cover}
      .sh{margin-bottom:28px}
      .sh h2{font-size:28px;letter-spacing:-0.02em;margin:0 0 8px}
      .sh p{font-size:16px;margin:0;max-width:600px}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}
      .c4{grid-column:span 4}
      .c3{grid-column:span 3}
      .c7{grid-column:span 7}
      .c5{grid-column:span 5}
      .card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:24px}
      .card-img{border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;margin-bottom:14px}
      .card-img img{width:100%;height:100%;object-fit:cover}
      .card h3{margin:0 0 6px;font-size:16px}
      .benefit-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
      .benefit-item{display:flex;gap:14px;padding:20px;background:#fff;border:1px solid #e2e8f0;border-radius:14px}
      .benefit-icon{flex-shrink:0;width:44px;height:44px;background:#e0f7fa;border-radius:10px;display:flex;align-items:center;justify-content:center}
      .benefit-text h3{margin:0 0 4px;font-size:15px;font-weight:700}
      .benefit-text p{margin:0;font-size:14px;color:#475569;line-height:1.5}
      .legacy-section{padding:40px 0;border-bottom:1px solid #e2e8f0}
      .legacy-inner{max-width:800px}
      .legacy-inner h2{font-size:26px;letter-spacing:-0.02em;margin:0 0 12px;color:#0d1b2a}
      .legacy-inner>p{font-size:15px;color:#475569;line-height:1.7;margin:0 0 24px}
      .legacy-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
      .legacy-card{background:#f0f9ff;border:1px solid #e0f2fe;border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:4px}
      .legacy-old{font-size:13px;color:#64748b}
      .legacy-arrow{font-size:11px;color:#0097a7;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
      .legacy-new{font-size:15px;font-weight:700;color:#0d1b2a}
      .legacy-new a{color:#0097a7;text-decoration:none}
      .legacy-new a:hover{text-decoration:underline}
      .pricing-grid-5{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
      .pricing-card{background:#fff;border:2px solid #e2e8f0;border-radius:20px;padding:20px;display:flex;flex-direction:column}
      .pricing-badge{display:inline-block;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em}
      .pricing-name{font-size:16px;font-weight:700;margin:0 0 2px}
      .pricing-platform{font-size:11px;color:#64748b;margin:0 0 10px}
      .pricing-price{font-size:24px;font-weight:800;line-height:1;margin:0 0 2px}
      .pricing-price-text{font-size:18px;font-weight:800;line-height:1;margin:0 0 2px}
      .pricing-note{font-size:11px;color:#64748b;margin:0 0 14px}
      .pricing-features{list-style:none;padding:0;margin:0 0 16px;flex:1}
      .pricing-features li{padding:4px 0;border-bottom:1px solid #f1f5f9;font-size:12px;color:#334155;display:flex;gap:5px;align-items:flex-start}
      .pricing-features li::before{content:"\2713";color:#0097a7;font-weight:700;flex-shrink:0}
      .pricing-btns{display:flex;flex-direction:column;gap:6px}
      .pricing-btns .btn{text-align:center;font-size:12px;padding:8px 12px}
      .tco-table{width:100%;border-collapse:collapse;margin-top:20px}
      .tco-table th{text-align:left;padding:10px 14px;font-size:12px;font-weight:600;color:#475569;border-bottom:2px solid #e2e8f0;background:#f8fafc}
      .tco-table td{padding:12px 14px;font-size:14px;border-bottom:1px solid #f1f5f9}
      .tco-note{font-size:12px;color:#94a3b8;margin-top:10px}
      .tco-disclaimer{font-size:11px;color:#94a3b8;margin-top:6px;font-style:italic}
      .step-num{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;font-weight:800;font-size:15px;margin-bottom:12px}
      .edition{background:rgba(255,255,255,.08);border-radius:12px;padding:14px;margin-bottom:8px}
      .edition-desc{font-size:13px;color:#cbd5e1;line-height:1.5}
      .footer-disclaimer{font-size:11px;color:#475569;line-height:1.6;margin-top:12px;padding-top:12px;border-top:1px solid #1e293b}
      footer{background:#0f172a;color:#64748b;padding:28px 0;font-size:14px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .stat-check{display:inline-block;width:14px;height:14px;margin-right:4px;vertical-align:middle;flex-shrink:0}

      @media(max-width:900px){
        .hero-inner{grid-template-columns:1fr}
        .hero h1{font-size:30px}
        .c6,.c4,.c3,.c7,.c5{grid-column:span 12}
        .sh h2{font-size:24px}
        .benefit-row{grid-template-columns:1fr}
        .pricing-grid-5{grid-template-columns:repeat(2,1fr)}
        .legacy-grid{grid-template-columns:1fr}
      }

      @media(max-width:600px){
        .nav-links{display:none}
        .nav-ctas .btn-secondary{display:none}
        .nav-ctas .btn-primary{padding:8px 16px;font-size:13px}
        .hamburger{display:flex}
        section{padding:32px 0}
        .hero{padding:28px 0 20px}
        .hero h1{font-size:24px}
        .hero p{font-size:14px}
        .sh h2{font-size:22px}
        .sh p{font-size:14px}
        .sh{margin-bottom:20px}
        .hero-btns{flex-direction:column}
        .hero-btns .btn-lg{width:100%;text-align:center;padding:12px 20px}
        .card{padding:16px}
        .pricing-card{padding:16px}
        .tco-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;border-radius:8px}
        .tco-table th,.tco-table td{padding:8px 10px;font-size:11px;white-space:nowrap}
        .stats-items{flex-direction:column;gap:6px;align-items:center}
        .footer-inner{flex-direction:column;align-items:center;text-align:center}
        .footer-links{justify-content:center}
        .pricing-grid-5{grid-template-columns:1fr}
      }
    </style>
  </head>
  <body>

    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo"><a href="/"><img src="/logo.jpg" alt={site.siteName} onerror="this.style.display='none'" /></a></div>
          <nav class="nav-links" aria-label="Primary">
            {site.navDropdown && (
              <div class="dropdown">
                <span class="dropdown-toggle">
                  {site.navDropdown.label}
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </span>
                <div class="dropdown-menu">
                  {site.navDropdown.items?.map((item) => <a href={item.url}>{item.label}</a>)}
                </div>
              </div>
            )}
            {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
          </nav>
          <div class="nav-ctas">
            {site.secondaryCTA?.text && <a class="btn btn-secondary" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>}
            <a class="btn btn-primary" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
            <button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'">
              <span></span><span></span><span></span>
            </button>
          </div>
        </div>
        <nav class="mobile-nav" aria-label="Mobile navigation">
          <a href="/">Home</a>
          {site.navDropdown?.items?.map((item) => <a href={item.url}>{item.label}</a>)}
          {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
        </nav>
      </div>
    </header>

    <main>

      <section class="hero">
        <div class="wrap">
          <div class="hero-inner">
            <div>
              <div class="hero-pill">{site.branding.industry} - {site.branding.region}</div>
              <h1>{site.branding.headline}</h1>
              <p>{site.branding.subheadline}</p>
              <div class="hero-btns">
                <a class="btn btn-primary btn-lg" href="/comparison">Compare Dragon Products</a>
                <a class="btn btn-secondary btn-lg" href="#final-cta">Enquire Now</a>
              </div>
            </div>
            <div class="hero-img">
              {imgSrc("hero")
                ? <img src={imgSrc("hero")} alt={imgAlt("hero")} loading="eager" decoding="async" />
                : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:14px">Hero image</div>
              }
            </div>
          </div>
        </div>
      </section>

      <div class="stats-bar" style="padding:12px 0">
        <div class="wrap">
          <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px">
            <div class="stats-savings" style="font-size:14px;font-weight:800;text-align:center">{site.branding.statsMessage}</div>
            <div class="stats-items" style="display:flex;gap:18px;flex-wrap:wrap;justify-content:center">
              {site.stats?.map((s) => (
                <div style="font-size:12px;color:#94a3b8;display:flex;align-items:center;gap:4px">
                  <svg class="stat-check" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="7" cy="7" r="7" fill="#0097a7" fill-opacity="0.2"/>
                    <path d="M3.5 7l2.5 2.5 4.5-5" stroke="#0097a7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span style="color:white;font-weight:600">{s.value}</span> {s.label}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- LEGACY BRAND SECTION - captures Dragon NaturallySpeaking and Dragon Dictate search intent -->
      <section class="legacy-section">
        <div class="wrap">
          <div class="legacy-inner">
            <h2>{site.branding.legacyHeading}</h2>
            <p>{site.branding.legacyBody}</p>
            <div class="legacy-grid">
              {site.branding.legacyProducts?.map((p) => (
                <div class="legacy-card">
                  <div class="legacy-old">{p.old}</div>
                  <div class="legacy-arrow">Is now</div>
                  <div class="legacy-new"><a href={p.url}>{p.new}</a></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="benefits">
        <div class="wrap">
          <div class="sh">
            <h2>{site.branding.benefitsHeading}</h2>
          </div>
          <div class="benefit-row">
            {site.benefits?.map((b) => (
              <div class="benefit-item">
                <div class="benefit-icon">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="11" fill="#0097a7" fill-opacity="0.15"/><path d="M6 11l3.5 3.5 6.5-7" stroke="#0097a7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="benefit-text">
                  <h3>{b.title}</h3>
                  <p>{b.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="pricing" class="neutral-bg">
        <div class="wrap">
          <div class="sh">
            <h2>{site.branding.pricingHeading}</h2>
            <p>{site.branding.pricingSubheading}</p>
          </div>
          <div class="pricing-grid-5">
            <div class="pricing-card">
              <div class="pricing-name">Dragon Medical One</div>
              <div class="pricing-platform">Cloud - subscription</div>
              <div class="pricing-price-text">Contact us</div>
              <div class="pricing-note">Volume discounts available</div>
              <ul class="pricing-features">
                <li>Multiple medical specialties</li>
                <li>Cloud - any device</li>
                <li>No voice training needed</li>
                <li>EHR integration</li>
              </ul>
              <div class="pricing-btns">
                <a class="btn btn-primary" href="https://www.voicerecognition.com.au/pages/dragon-medical-one" target="_blank" rel="noopener">Free Trial</a>
                <a class="btn btn-secondary" href="/dragon-medical-one">Learn more</a>
              </div>
            </div>
            <div class="pricing-card">
              <div class="pricing-name">Dragon Professional 16</div>
              <div class="pricing-platform">Windows desktop - perpetual</div>
              <div class="pricing-price">$994</div>
              <div class="pricing-note">AUD inc GST - one-time</div>
              <ul class="pricing-features">
                <li>Works offline</li>
                <li>Voice commands and macros</li>
                <li>Transcribe recordings</li>
                <li>Install on up to 2 PCs</li>
              </ul>
              <div class="pricing-btns">
                <a class="btn btn-primary" href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-download" target="_blank" rel="noopener">Buy now</a>
                <a class="btn btn-secondary" href="/dragon-professional-16">Learn more</a>
              </div>
            </div>
            <div class="pricing-card">
              <div class="pricing-name">Dragon Anywhere</div>
              <div class="pricing-platform">Cloud - subscription</div>
              <div class="pricing-price-text">Contact us</div>
              <div class="pricing-note">Per user per year</div>
              <ul class="pricing-features">
                <li>Cloud-based, always updated</li>
                <li>Virtual desktop and Citrix</li>
                <li>Centralised admin (NMC)</li>
                <li>Mobile app included</li>
              </ul>
              <div class="pricing-btns">
                <a class="btn btn-primary" href="https://www.voicerecognition.com.au/products/dragon-professional-anywhere" target="_blank" rel="noopener">Buy now</a>
                <a class="btn btn-secondary" href="/dragon-professional-anywhere">Learn more</a>
              </div>
            </div>
            <div class="pricing-card">
              <div class="pricing-name">Dragon Legal</div>
              <div class="pricing-platform">Cloud - subscription</div>
              <div class="pricing-price-text">Contact us</div>
              <div class="pricing-note">Legal vocabulary built in</div>
              <ul class="pricing-features">
                <li>Legal terminology</li>
                <li>Cloud-based</li>
                <li>Law firm deployment</li>
                <li>Centralised admin</li>
              </ul>
              <div class="pricing-btns">
                <a class="btn btn-primary" href="https://www.voicerecognition.com.au/products/dragon-legal-anywhere" target="_blank" rel="noopener">Buy now</a>
                <a class="btn btn-secondary" href="/dragon-legal">Learn more</a>
              </div>
            </div>
            <div class="pricing-card">
              <div class="pricing-name">Dragon Education</div>
              <div class="pricing-platform">Windows desktop - perpetual</div>
              <div class="pricing-price">$545</div>
              <div class="pricing-note">AUD inc GST - student price</div>
              <ul class="pricing-features">
                <li>Full Dragon Professional 16</li>
                <li>Accessibility and assistive</li>
                <li>NDIS eligible</li>
                <li>Own it forever</li>
              </ul>
              <div class="pricing-btns">
                <a class="btn btn-primary" href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-educational-student" target="_blank" rel="noopener">Buy now</a>
                <a class="btn btn-secondary" href="/dragon-education">Learn more</a>
              </div>
            </div>
          </div>
          <p style="font-size:12px;color:#94a3b8;margin-top:14px;text-align:center">All prices AUD inc GST as published by Voice Recognition Australia. Verify current pricing before purchase.</p>

          <div class="card" style="margin-top:28px">
            <h3 style="margin:0 0 4px;font-size:17px">{site.tco?.heading}</h3>
            <div class="tco-table-wrap">
              <table class="tco-table">
                <thead><tr><th>Scenario</th><th>Impact</th><th>Method</th></tr></thead>
                <tbody>
                  {site.tco?.rows?.map((r, i) => (
                    <tr class={i === 0 ? "winner" : ""}>
                      <td>{r.product}</td><td>{r.cost}</td><td>{r.type}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="tco-note">{site.tco?.note}</p>
          </div>
        </div>
      </section>

      <section id="about">
        <div class="wrap">
          <div class="grid">
            <div class="card c7">
              {imgSrc("about-banner") && <div class="card-img"><img src={imgSrc("about-banner")} alt={imgAlt("about-banner")} loading="lazy" decoding="async" /></div>}
              <h3 style="font-size:20px">{site.branding.aboutHeading}</h3>
              <p>{site.branding.aboutBody}</p>
              <div style="margin-top:14px;display:flex;flex-wrap:wrap;gap:6px">
                {site.proofPoints?.map((p) => (
                  <div style="background:#e0f7fa;border-radius:999px;padding:5px 12px;font-size:12px;font-weight:600;color:#006064">&#10003; {p}</div>
                ))}
              </div>
            </div>
            <div class="card c5" style={`background:${c.primary};color:white;border-color:${c.primary}`}>
              <h3 style="color:white;margin:0 0 14px;font-size:17px">Dragon product range</h3>
              {site.aboutEditions?.map((e) => (
                <div class="edition">
                  <div class="edition-name">{e.name}{e.highlight ? " - Recommended" : ""}</div>
                  <div class="edition-desc">{e.desc}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="how-it-works" class="neutral-bg">
        <div class="wrap">
          <div class="sh">
            <h2>How it works</h2>
            <p>{site.branding.howItWorksSubheading}</p>
          </div>
          <div class="grid">
            {site.steps?.map((s, i) => (
              <div class="card c4">
                <div class="step-num">{i + 1}</div>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="features">
        <div class="wrap">
          <div class="sh">
            <h2>{site.branding.featuresHeading}</h2>
            <p>{site.branding.featuresSubheading}</p>
          </div>
          <div class="grid">
            {site.features?.map((f) => (
              <div class="card c6">
                {imgSrc(f.key) && <div class="card-img"><img src={imgSrc(f.key)} alt={imgAlt(f.key)} loading="lazy" decoding="async" /></div>}
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="faq" class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>Frequently asked questions</h2></div>
          <div class="grid">
            {site.faqs?.map((f) => (
              <div class="card c6"><h3 style="font-size:15px">{f.q}</h3><p style="font-size:14px">{f.a}</p></div>
            ))}
          </div>
        </div>
      </section>

      <section id="final-cta" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              {imgSrc("cta-banner") && <div style="border-radius:14px;overflow:hidden;aspect-ratio:16/9;margin-bottom:20px"><img src={imgSrc("cta-banner")} alt={imgAlt("cta-banner")} loading="lazy" style="width:100%;height:100%;object-fit:cover" /></div>}
              <h2 style="color:white;font-size:26px;margin:0 0 10px">{site.branding.ctaHeading}</h2>
              <p style="color:#94a3b8;margin:0 0 16px;font-size:15px">{site.branding.ctaBody}</p>
              <ul style="color:#94a3b8;margin:0;padding-left:20px;line-height:2;font-size:14px">
                {site.branding.ctaBullets?.map((b) => <li>{b}</li>)}
              </ul>
            </div>
            <div class="c5">
              <ACForm />
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&#169; {year} {site.siteName}</div>
          <div class="footer-links">{site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}</div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>

  </body>
</html>
