---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";
const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";
function imgSrc(key) { const e = manifest[key]; if (!e?.r2Key || !R2_BASE) return ""; return `${R2_BASE.replace(/\/$/, "")}/${e.r2Key}`; }
function imgAlt(key) { return manifest[key]?.altText || ""; }
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dragon Professional 16 Australia | From $495 AUD | Buy, Upgrade, Subscribe</title>
    <meta name="description" content="Dragon Professional 16 for Windows. Perpetual licence $994, upgrade from v15 $495, annual subscription $595. Works offline after activation. Local Australian support from Voice Recognition Australia." />
    <link rel="canonical" href={`${site.domain}/dragon-professional-16`} />
    <script define:vars={{ c }}>
      const css = `.btn-primary{background:${c.accent};border-color:${c.accent};color:#fff}.btn-primary:hover{background:${c.accentHover};border-color:${c.accentHover}}.dark-bg{background:${c.primary};color:white}.neutral-bg{background:${c.neutral}}.feature-check{color:${c.accent}}.spec-badge{background:${c.accent};color:#fff}.nav-links a:hover,.dropdown-toggle:hover{color:${c.accent}}.dropdown-menu{border-top:2px solid ${c.accent}}`;
      const el=document.createElement('style');el.textContent=css;document.head.appendChild(el);
    </script>
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#0f172a;line-height:1.6}a{color:inherit;text-decoration:none}img{max-width:100%;display:block}.wrap{max-width:1080px;margin:0 auto;padding:0 24px}header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}.nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}.logo img{height:40px;width:auto}.nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155;align-items:center}.dropdown{position:relative}.dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap}.dropdown-toggle svg{transition:transform .15s}.dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}.dropdown-menu{display:none;position:absolute;top:100%;left:0;background:#fff;border:1px solid #e2e8f0;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.1);min-width:240px;padding:8px 0 6px;z-index:200}.dropdown:hover .dropdown-menu{display:block}.dropdown-menu a{display:block;padding:10px 16px;font-size:14px;font-weight:500;color:#334155;transition:background .1s}.dropdown-menu a:hover{background:#e0f7fa;color:#006064}.nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}.btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}.btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}.hamburger span{display:block;width:22px;height:2px;background:#334155;border-radius:2px}.mobile-nav{display:none;padding:12px 0 8px;border-top:1px solid #e2e8f0}.mobile-nav a{display:block;padding:10px 0;font-size:15px;font-weight:500;color:#334155;border-bottom:1px solid #f1f5f9}section{padding:48px 0}.breadcrumb{font-size:13px;color:#64748b;margin-bottom:18px}.breadcrumb a{color:#0097a7;font-weight:500}.product-hero{padding:40px 0 36px}.product-hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}.product-hero h1{font-size:32px;line-height:1.1;margin:0 0 12px;letter-spacing:-0.03em}.product-hero p{font-size:15px;line-height:1.7;margin:0 0 20px;color:#475569}.spec-badge{display:inline-block;font-size:11px;font-weight:700;padding:4px 12px;border-radius:999px;margin-bottom:12px;text-transform:uppercase;letter-spacing:.05em}.price-display{font-size:40px;font-weight:800;line-height:1;margin:0 0 4px;color:#0d1b2a}.price-note{font-size:13px;color:#64748b;margin:0 0 4px}.licence-note{font-size:12px;color:#64748b;margin:0 0 18px;padding:8px 12px;background:#f8fafc;border-radius:8px;border-left:3px solid #e2e8f0}.spec-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:14px}.spec-card{text-align:center;padding:12px;background:#f0f9ff;border-radius:10px}.spec-val{font-size:16px;font-weight:800;color:#0d1b2a}.spec-label{font-size:11px;color:#64748b}.sh{margin-bottom:28px}.sh h2{font-size:26px;letter-spacing:-0.02em;margin:0 0 6px}.sh p{font-size:15px;margin:0;color:#475569}.grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}.c6{grid-column:span 6}.c4{grid-column:span 4}.c7{grid-column:span 7}.c5{grid-column:span 5}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px}.card h3{margin:0 0 6px;font-size:16px}.card p{color:#475569;font-size:14px}.feature-list{list-style:none;padding:0;margin:0}.feature-list li{padding:8px 0;border-bottom:1px solid #f1f5f9;font-size:14px;display:flex;gap:8px;align-items:flex-start}.feature-list li:last-child{border-bottom:none}.feature-check{font-weight:700;flex-shrink:0;font-size:15px}.faq-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px}.faq-card h3{margin:0 0 6px;font-size:15px}.faq-card p{margin:0;font-size:14px;color:#475569}.compare-box{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:20px}.compare-card{border:2px solid #e2e8f0;border-radius:14px;padding:20px}.compare-card.recommended{border-color:#0097a7}.compare-card h3{margin:0 0 4px;font-size:18px}.compare-card .price{font-size:28px;font-weight:800;color:#0d1b2a;margin:8px 0 4px}.compare-card .note{font-size:12px;color:#64748b;margin:0 0 12px}.compare-card ul{list-style:none;padding:0;margin:0 0 16px}.compare-card li{padding:4px 0;font-size:13px;color:#334155}.compare-card li::before{content:"✓";color:#0097a7;font-weight:700;margin-right:6px}.formbox{background:#fff;border-radius:14px;padding:24px;display:flex;flex-direction:column;gap:14px}._form_element{margin-bottom:10px}._form_element input,._form_element textarea{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;color:#0f172a;font-size:14px;font-family:system-ui,-apple-system,sans-serif;padding:10px 12px;width:100%}._submit{border:none;border-radius:8px;font-weight:700;font-size:15px;padding:12px 20px;width:100%;margin-top:8px;cursor:pointer;background:#0097a7;color:#fff}._submit:hover{background:#00838f}footer{background:#0f172a;color:#64748b;padding:24px 0;font-size:13px}.footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}.footer-links{display:flex;gap:18px}.footer-links a:hover{color:white}.footer-disclaimer{font-size:11px;color:#475569;line-height:1.6;margin-top:10px;padding-top:10px;border-top:1px solid #1e293b}@media(max-width:900px){.product-hero-inner{grid-template-columns:1fr}.c6,.c4,.c7,.c5{grid-column:span 12}.sh h2{font-size:22px}.compare-box{grid-template-columns:1fr}}@media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}section{padding:36px 0}.product-hero{padding:24px 0}.product-hero h1{font-size:24px}.price-display{font-size:32px}.card,.faq-card,.formbox,.compare-card{padding:16px}.spec-grid{grid-template-columns:1fr}.footer-inner{flex-direction:column;align-items:center;text-align:center}.footer-links{justify-content:center}}
    </style>
  </head>
  <body>
    <header><div class="wrap"><div class="nav"><div class="logo"><a href="/"><img src="/logo.jpg" alt={site.siteName} onerror="this.style.display='none'" /></a></div><nav class="nav-links" aria-label="Primary">{site.navDropdown && (<div class="dropdown"><span class="dropdown-toggle">{site.navDropdown.label}<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span><div class="dropdown-menu">{site.navDropdown.items?.map((item) => <a href={item.url}>{item.label}</a>)}</div></div>)}{site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}</nav><div class="nav-ctas"><a class="btn btn-primary" href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-download" target="_blank" rel="noopener">Buy Now</a><button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'"><span></span><span></span><span></span></button></div></div><nav class="mobile-nav" aria-label="Mobile"><a href="/">Home</a>{site.navDropdown?.items?.map((item) => <a href={item.url}>{item.label}</a>)}<a href="/comparison">Comparison</a><a href="/news">News</a></nav></div></header>

    <main>
      <section class="product-hero">
        <div class="wrap">
          <div class="breadcrumb"><a href="/">Home</a> > <a href="/comparison">Products</a> > Dragon Professional 16</div>
          <div class="product-hero-inner">
            <div>
              <div class="spec-badge">Desktop - Perpetual Licence</div>
              <h1>Dragon Professional 16 - Desktop Speech Recognition for Windows</h1>
              <p>The locally installed professional speech recognition suite for Windows 10 and 11. Dictate into any application, transcribe single-speaker recordings, and automate workflows with custom voice commands. Works offline after activation.</p>
              <div class="price-display">$994</div>
              <div class="price-note">AUD inc GST - one-time perpetual licence</div>
              <div class="licence-note">Licensed per user. Install on up to 2 PCs. Upgrade from v15: $495.</div>
              <div style="display:flex;gap:10px;flex-wrap:wrap">
                <a class="btn btn-primary btn-lg" href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-download" target="_blank" rel="noopener">Buy Dragon Professional 16</a>
                <a class="btn" href="#cta" style="border-color:#cbd5e1;color:#334155">Contact Us</a>
              </div>
            </div>
            <div>
              {imgSrc("feature-professional") && (<div style="border-radius:14px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 12px 40px rgba(0,0,0,.12)"><img src={imgSrc("feature-professional")} alt={imgAlt("feature-professional")} loading="eager" decoding="async" style="width:100%;height:100%;object-fit:cover" /></div>)}
              <div class="spec-grid">
                <div class="spec-card"><div class="spec-val">$994</div><div class="spec-label">Perpetual AUD</div></div>
                <div class="spec-card"><div class="spec-val">Up to 2</div><div class="spec-label">PC installs</div></div>
                <div class="spec-card"><div class="spec-val">Offline</div><div class="spec-label">After activation</div></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>Perpetual vs Annual Subscription</h2><p>Two ways to licence Dragon Professional 16. Choose the model that suits your needs.</p></div>
          <div class="compare-box">
            <div class="compare-card recommended">
              <div style="font-size:11px;font-weight:700;color:#0097a7;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Perpetual Licence</div>
              <h3>Own it forever</h3>
              <div class="price">$994</div>
              <div class="note">AUD inc GST - one-time purchase</div>
              <ul>
                <li>Pay once, use indefinitely</li>
                <li>Install on up to 2 Windows PCs</li>
                <li>Cheaper over 2+ years</li>
                <li>Upgrade from v15: $495</li>
              </ul>
              <a class="btn btn-primary" href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-download" target="_blank" rel="noopener" style="text-align:center;width:100%">Buy Perpetual</a>
            </div>
            <div class="compare-card">
              <div style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Annual Subscription</div>
              <h3>Flexible multi-PC access</h3>
              <div class="price">$595</div>
              <div class="note">AUD inc GST per year</div>
              <ul>
                <li>Install on unlimited Windows PCs</li>
                <li>One user, one voice profile</li>
                <li>Nuance Management Centre compatible</li>
                <li>Renews annually</li>
              </ul>
              <a class="btn btn-primary" href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-annual-subscription" target="_blank" rel="noopener" style="text-align:center;width:100%">Buy Subscription</a>
            </div>
          </div>
          <p style="font-size:12px;color:#94a3b8;margin-top:14px">Over 3 years: perpetual costs $994 once vs subscription at $1,785 ($595 x 3). The subscription suits users who need multi-PC flexibility or prefer annual billing. All prices AUD inc GST.</p>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <div class="sh"><h2>What Dragon Professional 16 includes</h2></div>
              <div class="card">
                <ul class="feature-list">
                  <li><span class="feature-check">✓</span>Real-time dictation into Word, Outlook, and hundreds of Windows applications</li>
                  <li><span class="feature-check">✓</span>Transcribe single-speaker audio recordings (MP3, WAV, WMA, DSS, DS2)</li>
                  <li><span class="feature-check">✓</span>Custom vocabulary - add industry terms, names, and shortcuts</li>
                  <li><span class="feature-check">✓</span>AutoText - speak a short phrase to insert a full paragraph</li>
                  <li><span class="feature-check">✓</span>Voice macros to automate multi-step Windows workflows</li>
                  <li><span class="feature-check">✓</span>Works offline after installation and activation</li>
                  <li><span class="feature-check">✓</span>Hands-free PC control, navigation, and mouse control</li>
                  <li><span class="feature-check">✓</span>Windows 10 and Windows 11 (32-bit and 64-bit) compatible</li>
                  <li><span class="feature-check">✓</span>Compatible with Microsoft 365, Google Docs, and Microsoft Teams</li>
                </ul>
              </div>
            </div>
            <div class="c5">
              <div class="card" style="margin-top:0;background:#0d1b2a;color:white;border-color:#0d1b2a">
                <h3 style="color:white;margin:0 0 14px;font-size:16px">Other buying options</h3>
                <div style="background:rgba(255,255,255,.08);border-radius:10px;padding:14px;margin-bottom:8px">
                  <div style="color:#0097a7;font-weight:700;font-size:14px;margin-bottom:2px">Upgrade from v15 - $495</div>
                  <div style="font-size:13px;color:#cbd5e1">Existing Dragon Professional 15 users. Your profiles carry over.</div>
                  <a href="https://www.voicerecognition.com.au/collections/dragon-professional/products/dragon-professional-16-upgrade" target="_blank" rel="noopener" style="font-size:12px;color:#0097a7;font-weight:600;display:inline-block;margin-top:4px">Buy upgrade</a>
                </div>
                <div style="background:rgba(255,255,255,.08);border-radius:10px;padding:14px;margin-bottom:8px">
                  <div style="color:#0097a7;font-weight:700;font-size:14px;margin-bottom:2px">Student / Education - $545</div>
                  <div style="font-size:13px;color:#cbd5e1">Full version at discounted pricing for students and educators.</div>
                  <a href="/dragon-education" style="font-size:12px;color:#0097a7;font-weight:600;display:inline-block;margin-top:4px">Learn more</a>
                </div>
                <div style="background:rgba(255,255,255,.08);border-radius:10px;padding:14px">
                  <div style="color:#0097a7;font-weight:700;font-size:14px;margin-bottom:2px">Enterprise / Group - Enquire</div>
                  <div style="font-size:13px;color:#cbd5e1">Teams of 5+. Centralised management via Nuance Management Centre.</div>
                  <a href="https://www.voicerecognition.com.au/pages/dragon-professional-group-enterprise" target="_blank" rel="noopener" style="font-size:12px;color:#0097a7;font-weight:600;display:inline-block;margin-top:4px">Enquire</a>
                </div>
              </div>
              <p style="font-size:12px;color:#94a3b8;margin-top:10px">For detailed version comparison across all five licensing options, visit <a href="https://dragonprofessional16.com.au/comparison" target="_blank" rel="noopener" style="color:#0097a7;font-weight:600">dragonprofessional16.com.au</a></p>
            </div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>What Dragon Professional 16 does not do</h2><p>Important limitations to be aware of before purchasing.</p></div>
          <div class="grid">
            <div class="card c4"><h3>Not for meetings</h3><p>Dragon Professional 16 is designed for single-speaker dictation and transcription only. It will not reliably transcribe multi-speaker conversations, meetings, or interviews.</p></div>
            <div class="card c4"><h3>Windows only</h3><p>Dragon Professional 16 is a Windows-only product (Windows 10 and 11). Nuance discontinued Dragon for Mac. There is no Mac version available.</p></div>
            <div class="card c4"><h3>English only</h3><p>Supports English across six regional variants: Australian, New Zealand, UK, US, Canadian, and Indian English. No other languages are supported.</p></div>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh"><h2>Frequently asked questions</h2></div>
          <div class="grid">
            <div class="faq-card c6"><h3>Does Dragon Professional 16 require internet to use?</h3><p>No. After installation and activation, Dragon Professional 16 operates without an internet connection. An internet connection is required only for the initial download and product activation.</p></div>
            <div class="faq-card c6"><h3>Can it transcribe audio recordings?</h3><p>Yes - single-speaker recordings only. Supported formats include MP3, WAV, WMA, DS2, and DSS. It cannot transcribe multi-speaker conversations or meetings.</p></div>
            <div class="faq-card c6"><h3>Which microphone should I use?</h3><p>Dragon works with a range of USB and 3.5mm microphones. A dedicated dictation microphone or USB headset provides the best accuracy. Apple AirPods are not supported for dictation.</p></div>
            <div class="faq-card c6"><h3>Does it work with Microsoft Teams?</h3><p>Dragon Professional 16 includes support for dictating into Microsoft Teams. Some advanced voice commands may have limitations in Teams Home edition.</p></div>
            <div class="faq-card c6"><h3>What is the difference between perpetual and subscription?</h3><p>The perpetual licence ($994) lets you install on up to 2 PCs and own the software forever. The annual subscription ($595/yr) lets you install on unlimited PCs but renews each year. Over 2+ years, perpetual is cheaper.</p></div>
            <div class="faq-card c6"><h3>Can I upgrade from an older version?</h3><p>The upgrade ($495) is available for Dragon Professional Individual or Group version 15 only. It is not valid for older versions or other editions such as Dragon Home.</p></div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh"><h2>Other Dragon products</h2></div>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            <a href="/dragon-medical-one" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Medical One</a>
            <a href="/dragon-professional-anywhere" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Professional Anywhere</a>
            <a href="/dragon-legal" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon Legal</a>
            <a href="/dragon-education" style="padding:8px 14px;border-radius:8px;border:1px solid #e2e8f0;font-size:13px;font-weight:600;color:#334155">Dragon for Education</a>
          </div>
          <div style="margin-top:14px"><a class="btn btn-primary" href="/comparison">Compare all products</a></div>
        </div>
      </section>

      <section id="cta" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <h2 style="color:white;font-size:26px;margin:0 0 10px">Questions about Dragon Professional 16?</h2>
              <p style="color:#94a3b8;margin:0 0 16px;font-size:14px">Voice Recognition Australia has deployed Dragon Professional across Australian government, legal, and enterprise environments for 25 years. We can help you choose the right version and get set up quickly.</p>
              <ul style="color:#94a3b8;margin:0;padding-left:20px;line-height:2;font-size:14px"><li>Which licence type suits your needs</li><li>Upgrade eligibility from older versions</li><li>Enterprise deployment and management</li><li>Microphone recommendations</li></ul>
            </div>
            <div class="c5">
              <div class="formbox">
                <div style="font-weight:800;font-size:18px;color:#0f172a">Get in touch</div>
                <div style="color:#475569;font-size:14px;margin-bottom:2px">Local Australian support. Fast response.</div>
                <form method="POST" action="https://voicerecognition.activehosted.com/proc.php" novalidate>
                  <input type="hidden" name="u" value={site.form.hiddenU} /><input type="hidden" name="f" value={site.form.hiddenF} /><input type="hidden" name="s" /><input type="hidden" name="c" value="0" /><input type="hidden" name="m" value="0" /><input type="hidden" name="act" value="sub" /><input type="hidden" name="v" value="2" /><input type="hidden" name="or" value={site.form.hiddenOr} />
                  <div class="_form_element"><input type="text" name="firstname" placeholder="Your Name" required /></div>
                  <div class="_form_element"><input type="text" name="email" placeholder="Your Email" required /></div>
                  <div class="_form_element"><input type="text" name="phone" placeholder="Your Phone Number" /></div>
                  <div class="_form_element"><input type="text" name="field[21]" placeholder="Number of Users" /></div>
                  <div class="_form_element"><input type="text" name="field[35]" placeholder="Company / Organisation" /></div>
                  <div class="_form_element"><textarea name="field[18]" placeholder="Your profession and current dictation setup"></textarea></div>
                  <button class="_submit" type="submit">{site.form.submitText}</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <footer><div class="wrap"><div class="footer-inner"><div>&copy; {year} {site.siteName}</div><div class="footer-links">{site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}</div></div><div class="footer-disclaimer">{site.branding.footerDisclaimer}</div></div></footer>
  </body>
</html>
